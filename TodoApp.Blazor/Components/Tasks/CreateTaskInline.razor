@namespace TodoApp.Blazor.Components.Tasks

@using TodoApp.Contracts.TodoTasks
@using TodoApp.Contracts.TodoTasks.Enums
@using TodoApp.Blazor.Forms

@inject TodoApp.Blazor.Services.TodoTaskApiClient TaskApi

@if (!_isExpanded)
{
    <!-- COLLAPSED: action only (NOT a task row) -->
    <div class="create-task-inline-grid add-task-inline-row">

        <!-- Task column -->
        <div class="add-task-button-cell">
            <button type="button"
                    class="add-task-inline-btn"
                    @onclick="Expand">
                <span class="add-icon">＋</span>
                <span>Add task</span>
            </button>
        </div>

        <!-- fillers to keep grid structure -->
        <div></div>
        <div></div>
        <div></div>
        <div></div>
        <div></div>

    </div>
}
else
{
    <!-- EXPANDED: create task row -->
    <EditForm Model="_form" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="create-task-inline-grid add-task-inline-row">

            <!-- Task -->
            <InputText class="form-control form-control-sm"
                       placeholder="Task title…"
                       @bind-Value="_form.Title"
                       disabled="@_isSubmitting"
                       autofocus />

            <!-- Status (placeholder) -->
            <div></div>

            <!-- Due -->
            <InputDate TValue="DateTime?"
                       class="form-control form-control-sm"
                       @bind-Value="_form.DueAt"
                       disabled="@_isSubmitting" />

            <!-- Overdue (placeholder) -->
            <div></div>

            <!-- Priority -->
            <InputSelect TValue="TodoTaskPriority"
                         class="form-select form-select-sm"
                         @bind-Value="_form.Priority"
                         disabled="@_isSubmitting">
                @foreach (var p in Enum.GetValues<TodoTaskPriority>())
                {
                    <option value="@p">
                        @(p == TodoTaskPriority.None ? "No prio" : p.ToString())
                    </option>
                }
            </InputSelect>

            <!-- Actions -->
            <div class="create-task-actions">
                <button type="submit"
                        class="icon-btn primary"
                        title="Add task"
                        disabled="@IsSubmitDisabled">
                    +
                </button>

                <button type="button"
                        class="icon-btn"
                        title="Cancel"
                        disabled="@_isSubmitting"
                        @onclick="Cancel">
                    ✕
                </button>
            </div>

        </div>
    </EditForm>
}

@code {

    [Parameter, EditorRequired]
    public Guid ListId { get; set; }

    [Parameter]
    public EventCallback OnCreated { get; set; }

    private readonly CreateTodoTaskForm _form = new();
    private bool _isSubmitting;
    private bool _isExpanded;

    private bool IsSubmitDisabled =>
        _isSubmitting || string.IsNullOrWhiteSpace(_form.Title);

    private void Expand()
    {
        _isExpanded = true;
    }

    private void Cancel()
    {
        ResetForm();
        _isExpanded = false;
    }

    private async Task HandleSubmit()
    {
        if (_isSubmitting) return;

        _isSubmitting = true;

        try
        {
            DateTimeOffset? dueAtUtc = null;

            if (_form.DueAt.HasValue)
            {
                dueAtUtc = new DateTimeOffset(
                    DateTime.SpecifyKind(_form.DueAt.Value, DateTimeKind.Utc)
                );
            }

            var request = new CreateTodoTaskRequest(
                ListId,
                _form.Title.Trim(),
                _form.Description,
                _form.Priority,
                dueAtUtc
            );

            await TaskApi.CreateAsync(ListId, request);

            ResetForm();
            _isExpanded = false;

            await OnCreated.InvokeAsync();
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void ResetForm()
    {
        _form.Title = string.Empty;
        _form.Description = null;
        _form.DueAt = null;
        _form.Priority = TodoTaskPriority.None;
    }
}
