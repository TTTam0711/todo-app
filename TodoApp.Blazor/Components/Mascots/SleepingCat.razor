<div class="sleeping-cat-wrapper">
    <!-- SVG mèo bạn đã chuẩn bị -->
    <svg class="cat sleeping" viewBox="0 0 200 120">
        <svg class="cat sleeping"
             viewBox="0 0 200 120"
             width="220"
             height="140"
             xmlns="http://www.w3.org/2000/svg">

            <!-- BODY -->
            <g class="body">
                <ellipse cx="110" cy="75" rx="65" ry="30" fill="#F3CFA6" />
            </g>

            <!-- BELLY (thở) -->
            <g class="belly">
                <ellipse cx="110" cy="80" rx="42" ry="20" fill="#F8E1C4" />
            </g>

            <!-- HEAD -->
            <g class="head">
                <circle cx="55" cy="60" r="22" fill="#F3CFA6" />

                <!-- EARS -->
                <g class="ears">
                    <polygon points="40,40 45,25 50,40" fill="#F3CFA6" />
                    <polygon points="60,40 65,25 70,40" fill="#F3CFA6" />
                </g>

                <!-- EYES (nhắm) -->
                <g class="eyes">
                    <line x1="47" y1="60" x2="53" y2="60"
                          stroke="#6B4A2E" stroke-width="2" />
                    <line x1="57" y1="60" x2="63" y2="60"
                          stroke="#6B4A2E" stroke-width="2" />
                </g>
            </g>

            <!-- TAIL -->
            <g class="tail">
                <path d="M155 78 C175 82, 175 98, 155 98"
                      stroke="#F3CFA6"
                      stroke-width="10"
                      fill="none"
                      stroke-linecap="round" />
            </g>

        </svg>

    </svg>

    <div class="empty-text">
        Không có công việc nào hôm nay 😴
    </div>
</div>
