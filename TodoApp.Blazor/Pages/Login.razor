@page "/login"
@layout LandingLayout

@using TodoApp.Blazor.Forms
@using TodoApp.Blazor.Services
@using TodoApp.Blazor.ViewModels.Auth
@using TodoApp.Contracts.Auth

@inject AuthApiClient AuthApi
@inject AuthState AuthState
@inject NavigationManager Nav

<h3>Login</h3>

<div class="card p-3" style="max-width:420px;">
    <EditForm Model="_form" OnValidSubmit="LoginAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-2">
            <label>Email</label>
            <InputText class="form-control" @bind-Value="_form.Email" />
        </div>

        <div class="mb-2">
            <label>Password</label>
            <InputText class="form-control" type="password" @bind-Value="_form.Password" />
        </div>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger mt-2">@_error</div>
        }

        <button class="btn btn-primary w-100" type="submit" disabled="@_isLoading">
            @(_isLoading ? "Logging in..." : "Login")
        </button>

        <div class="mt-3 text-center">
            <a href="/register">Create account</a>
        </div>
    </EditForm>
</div>

@code {
    private LoginForm _form = new();
    private bool _isLoading;
    private string? _error;

    private async Task LoginAsync()
    {
        _error = null;
        _isLoading = true;

        try
        {
            // 🔥 FIX: LoginRequest không có constructor => dùng object initializer
            var res = await AuthApi.LoginAsync(new LoginRequest
            {
                Email = _form.Email,
                Password = _form.Password
            });

            AuthState.Set(
                res.AccessToken,
                res.ExpiresIn,
                res.User.UserId,
                res.User.Email,
                res.User.DisplayName);

            Nav.NavigateTo("/dashboard", true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
