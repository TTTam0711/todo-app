@page "/calendar"

@using TodoApp.Blazor.ViewModels.Calendar
@using TodoApp.Blazor.ViewModels.MyTask
@using TodoApp.Contracts.TodoLists
@using TodoApp.Contracts.TodoTasks
@using TodoApp.Blazor.Components.Tasks
@using TodoApp.Blazor.Components.Calendars
@using TodoApp.Blazor.Components.Mascots
@using Microsoft.AspNetCore.Components.Web
@using Radzen
@using Radzen.Blazor
@using TodoApp.Contracts.TodoTasks.Enums

@inject TodoApp.Blazor.Services.TodoListApiClient ListApi
@inject TodoApp.Blazor.Services.TodoTaskApiClient TaskApi
@inject TooltipService TooltipService

<div class="calendar-root"
     @onmousemove="OnMouseMove"
     @onmouseup="OnGlobalMouseUp">

    <!-- ================= PAGE HEADER ================= -->
    <div class="calendar-header-bar">
        <h2 class="calendar-title">Calendar</h2>

        @if (!_isLoadingLists && _lists.Count > 0)
        {
            <select class="calendar-list-select"
                    @onchange="OnListChanged">
                @foreach (var list in _lists)
                {
                    <option value="@list.ListId"
                            selected="@(list.ListId == _selectedList?.ListId)">
                        @list.Name
                    </option>
                }
            </select>
        }

        <div class="calendar-nav">
            <button class="nav-btn" @onclick="GoToPrevMonth">←</button>
            <span class="month-label">
                @_calendarState.CurrentMonth.ToString("MMMM yyyy")
            </span>
            <button class="nav-btn" @onclick="GoToNextMonth">→</button>
        </div>
    </div>

    @if (_isLoadingLists)
    {
        <p class="calendar-loading">Loading lists…</p>
    }
    else if (_lists.Count == 0)
    {
        <p class="calendar-empty">No lists</p>
    }
    else if (_isLoadingTasks)
    {
        <p class="calendar-loading">Loading tasks…</p>
    }
    else
    {
        <!-- ================= CALENDAR CARD ================= -->
        <div class="calendar-card">

            <div class="calendar-grid">

                <!-- WEEK HEADER -->
                <div class="calendar-header">Sun</div>
                <div class="calendar-header">Mon</div>
                <div class="calendar-header">Tue</div>
                <div class="calendar-header">Wed</div>
                <div class="calendar-header">Thu</div>
                <div class="calendar-header">Fri</div>
                <div class="calendar-header">Sat</div>

                @foreach (var day in GetCalendarDays())
                {
                    var isCurrentMonth = day.Month == _calendarState.CurrentMonth.Month;
                    var isToday = day == DateOnly.FromDateTime(DateTime.Today);

                    <div class="calendar-cell @(isCurrentMonth ? "" : "other-month") @(isToday ? "today" : "")"
                         @onmousedown="() => StartCellDrag(day)"
                         @onmouseup="() => DropOnCell(day)"
                         @onclick="() => OpenQuickCreate(day)">

                        <div class="day-number">@day.Day</div>

                        @if (_tasksByDate.TryGetValue(day, out var tasks))
                        {
                            <div class="calendar-tasks"
                                 @onclick:stopPropagation="true">

                                @foreach (var task in tasks.Take(2))
                                {
                                    <div class="calendar-task clickable
                                                                        @(task.IsOverdue ? "overdue" : "")
                                                                        @GetPriorityClass(task)"
                                         @ref="_taskRefs[task.TaskId]"
                                         @onmouseenter="() => ShowTooltip(task)"
                                         @onmouseleave="HideTooltip"
                                         @onclick="() => OpenTaskDetail(task.TaskId)">
                                        @task.Title
                                        @if (task.IsOverdue)
                                        {
                                            <span class="calendar-overdue">⏰</span>
                                        }
                                    </div>
                                }

                                @if (tasks.Count > 2)
                                {
                                    <div class="calendar-more clickable"
                                         @onclick="() => OpenDay(day)">
                                        + @(tasks.Count - 2) more
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="calendar-mascot">

                <img class="mascot-img"
                     src="@(HasAnyTaskInCurrentMonth
                                         ? "images/cat-awake.png"
                                         : "images/cat-sleep.png")"
                 alt="Mascot" />

                <div class="mascot-title">@MascotTitle</div>
                <div class="mascot-subtitle">@MascotSubtitle</div>

            </div>
            <div class="priority-legend">
                <div class="legend-item">
                    <span class="legend-dot high"></span>
                    High
                </div>

                <div class="legend-item">
                    <span class="legend-dot medium"></span>
                    Medium
                </div>

                <div class="legend-item">
                    <span class="legend-dot low"></span>
                    Low
                </div>

                <div class="legend-item">
                    <span class="legend-dot optional"></span>
                    Optional
                </div>
            </div>
        </div>
        
    }

    <!-- ================= GHOST ================= -->
    @if (_draggingTask != null)
    {
        <div class="calendar-task ghost-task"
             style="left:@($"{_mouseX}px"); top:@($"{_mouseY}px");">
            @_draggingTask.Title
        </div>
    }

    <!-- ================= DAY PANEL ================= -->
    @if (_openedDay.HasValue &&
        _tasksByDate.TryGetValue(_openedDay.Value, out var dayTasks))
    {
        <CalendarDayPanel Date="_openedDay.Value"
                          Tasks="dayTasks"
                          OnClose="@(() => _openedDay = null)"
                          OnTaskSelected="OnTaskSelectedFromDay" />
    }

    <!-- ================= QUICK CREATE ================= -->
    @if (_quickCreateDay.HasValue && _selectedList != null)
    {
        <CreateTaskQuickPanel Date="_quickCreateDay.Value"
                              ListId="_selectedList.ListId"
                              OnCreated="ReloadTasks"
                              OnClose="@(() => _quickCreateDay = null)" />
    }

    <!-- ================= DETAIL ================= -->
    @if (_openedTaskId.HasValue)
    {
        <TaskDetailPanel TaskId="_openedTaskId.Value"
                         OnClose="@(() => _openedTaskId = null)"
                         OnTaskChanged="ReloadTasks" />
    }

</div>

@code {

    // ================= STATE =================
    private readonly Guid _ownerUserId =
        Guid.Parse("7D97D295-C6F0-F011-9685-782B464EB9F6");

    private IReadOnlyList<TodoListDto> _lists = [];
    private TodoListDto? _selectedList;
    private bool _isLoadingLists;

    private readonly MonthCalendarState _calendarState = new();

    private IReadOnlyList<TodoTaskListItemDto> _tasks = [];
    private Dictionary<DateOnly, List<TodoTaskListItemDto>> _tasksByDate = new();
    private bool _isLoadingTasks;

    private DateOnly? _openedDay;
    private Guid? _openedTaskId;
    private DateOnly? _quickCreateDay;

    // ================= DRAG =================
    private TodoTaskListItemDto? _draggingTask;
    private double _mouseX;
    private double _mouseY;

    private Dictionary<Guid, ElementReference> _taskRefs = new();

    private readonly TaskFilterState _filter = new()
    {
        SortByDue = true,
        DueDirection = SortDirection.Asc
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadListsAsync();
        if (_selectedList != null)
            await LoadTasksAsync();
    }

    private async Task LoadListsAsync()
    {
        _isLoadingLists = true;
        _lists = await ListApi.GetByOwnerAsync(_ownerUserId);
        _selectedList = _lists.FirstOrDefault();
        _isLoadingLists = false;
    }

    private async Task LoadTasksAsync()
    {
        if (_selectedList == null) return;

        _isLoadingTasks = true;

        var from = new DateTimeOffset(
            _calendarState.GridStartDate.ToDateTime(TimeOnly.MinValue),
            TimeSpan.Zero);

        var to = new DateTimeOffset(
            _calendarState.GridEndDate.ToDateTime(TimeOnly.MaxValue),
            TimeSpan.Zero);

        _tasks = await TaskApi.QueryAsync(
            _selectedList.ListId,
            _filter,
            from,
            to);

        _tasksByDate = _tasks
            .Where(t => t.DueAt.HasValue)
            .GroupBy(t => DateOnly.FromDateTime(t.DueAt!.Value.DateTime))
            .ToDictionary(g => g.Key, g => g.ToList());

        _taskRefs = _tasks.ToDictionary(t => t.TaskId, _ => new ElementReference());

        _isLoadingTasks = false;
    }

    private IEnumerable<DateOnly> GetCalendarDays()
    {
        var d = _calendarState.GridStartDate;
        while (d <= _calendarState.GridEndDate)
        {
            yield return d;
            d = d.AddDays(1);
        }
    }

    // ================= LIST =================
    private async Task OnListChanged(ChangeEventArgs e)
    {
        if (!Guid.TryParse(e.Value?.ToString(), out var listId))
            return;

        if (_selectedList?.ListId == listId)
            return;

        _selectedList = _lists.FirstOrDefault(l => l.ListId == listId);

        _openedDay = null;
        _openedTaskId = null;
        _quickCreateDay = null;
        _draggingTask = null;

        await LoadTasksAsync();
    }

    // ================= DRAG =================
    private void StartCellDrag(DateOnly day)
    {
        if (_tasksByDate.TryGetValue(day, out var tasks))
            _draggingTask = tasks.FirstOrDefault();
    }

    private async Task DropOnCell(DateOnly targetDay)
    {
        if (_draggingTask == null || _selectedList == null) return;

        await TaskApi.ChangeDueDateAsync(
            _draggingTask.TaskId,
            new ChangeTodoTaskDueDateRequest(
                new DateTimeOffset(
                    targetDay.ToDateTime(TimeOnly.MinValue),
                    TimeSpan.Zero)));

        _draggingTask = null;
        await LoadTasksAsync();
    }

    private void OnGlobalMouseUp()
    {
        _draggingTask = null;
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (_draggingTask == null) return;
        _mouseX = e.ClientX + 12;
        _mouseY = e.ClientY + 12;
    }

    // ================= UI =================
    private void OpenDay(DateOnly day) => _openedDay = day;
    private void OpenTaskDetail(Guid id) => _openedTaskId = id;
    private void OpenQuickCreate(DateOnly day) => _quickCreateDay = day;

    private void OnTaskSelectedFromDay(Guid taskId)
    {
        _openedDay = null;
        _openedTaskId = taskId;
    }

    private async Task ReloadTasks()
    {
        await LoadTasksAsync();
    }

    // ================= TOOLTIP =================
    private void ShowTooltip(TodoTaskListItemDto task)
    {
        TooltipService.Open(_taskRefs[task.TaskId], ts =>
        @<RadzenStack Orientation="Orientation.Vertical"
                              Gap="4px"
                              class="rz-p-4">
            <RadzenText TextStyle="TextStyle.H6">@task.Title</RadzenText>
        </RadzenStack>);
    }

    private void HideTooltip() => TooltipService.Close();

    private async Task GoToPrevMonth()
    {
        _calendarState.GoToPreviousMonth();
        await LoadTasksAsync();
    }

    private async Task GoToNextMonth()
    {
        _calendarState.GoToNextMonth();
        await LoadTasksAsync();
    }

    private bool HasAnyTaskInCurrentMonth =>
        _tasks.Any(t =>
            t.DueAt.HasValue &&
            t.DueAt.Value.DateTime.Year == _calendarState.CurrentMonth.Year &&
            t.DueAt.Value.DateTime.Month == _calendarState.CurrentMonth.Month);
    private string MascotTitle =>
        HasAnyTaskInCurrentMonth
        ? "Let’s get things done ✨"
        : "No tasks yet 😊";

    private string MascotSubtitle =>
        HasAnyTaskInCurrentMonth
            ? "Your tasks are waiting — I’ll keep an eye on them 🐾"
            : "Add something you don’t want to forget 🐾";

    private string GetPriorityClass(TodoTaskListItemDto task)
    {
        // Đổi "task.Priority" theo đúng field thật trong DTO của bạn
        return task.Priority switch
        {
            TodoTaskPriority.High => "priority-high",
            TodoTaskPriority.Medium => "priority-medium",
            TodoTaskPriority.Low => "priority-low",
            TodoTaskPriority.Optional => "priority-optional",
            _ => "priority-none"
        };
    }
}
