@page "/register"
@layout LandingLayout

@using TodoApp.Blazor.Forms
@using TodoApp.Blazor.Services
@using TodoApp.Contracts.Auth

@inject AuthApiClient AuthApi
@inject NavigationManager Nav

<h3>Register</h3>

<div class="card p-3" style="max-width:420px;">
    <EditForm Model="_form" OnValidSubmit="RegisterAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-2">
            <label>Email</label>
            <InputText class="form-control" @bind-Value="_form.Email" />
        </div>

        <div class="mb-2">
            <label>Password</label>
            <InputText class="form-control" type="password" @bind-Value="_form.Password" />
        </div>

        <div class="mb-2">
            <label>Display Name</label>
            <InputText class="form-control" @bind-Value="_form.DisplayName" />
        </div>

        @if (!string.IsNullOrWhiteSpace(_success))
        {
            <div class="alert alert-success mt-2">@_success</div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger mt-2">@_error</div>
        }

        <button class="btn btn-success w-100" type="submit" disabled="@_isLoading">
            @(_isLoading ? "Creating..." : "Create account")
        </button>

        <div class="mt-3 text-center">
            <a href="/login">Back to login</a>
        </div>
    </EditForm>
</div>

@code {
    private RegisterForm _form = new();
    private bool _isLoading;
    private string? _error;
    private string? _success;

    private async Task RegisterAsync()
    {
        _error = null;
        _success = null;
        _isLoading = true;

        try
        {
            // 🔥 FIX: RegisterRequest không có constructor => dùng object initializer
            await AuthApi.RegisterAsync(new RegisterRequest
            {
                Email = _form.Email,
                Password = _form.Password,
                DisplayName = _form.DisplayName
            });

            _success = "Register success! Redirecting to login...";
            await Task.Delay(800);

            Nav.NavigateTo("/login", true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
